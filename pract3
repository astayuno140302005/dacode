//british corpus

library(topicmodels)

# Set working directory (make sure this path is correct)
setwd("C:\\Users\\Admin\\Downloads\\british-fiction-corpus\\british-fiction-corpus-master")

# List all text files in the directory
filenames <- list.files(path = ".", pattern = "\\.txt$", ignore.case = TRUE)
filenames
# Read all files and store their content in a list
filetext <- lapply(filenames, readLines)

# Create a Corpus from the text files
mycorpus <- Corpus(VectorSource(filetext))

# Preprocess the corpus (remove numbers, punctuation, convert to lowercase, etc.)
mycorpus <- tm_map(mycorpus, content_transformer(tolower))    # Convert to lowercase
mycorpus <- tm_map(mycorpus, removeNumbers)                    # Remove numbers
mycorpus <- tm_map(mycorpus, removePunctuation)                # Remove punctuation

# Define custom stopwords
mystopwords <- c("of", "a", "and", "the", "in", "to", "for", "that", "is", "on", "are", 
                 "with", "as", "by", "be", "an", "which", "it", "from", "or", "can", 
                 "have", "these", "has", "such")

# Remove custom stopwords from the corpus
mycorpus <- tm_map(mycorpus, removeWords, mystopwords)

# Create a Document-Term Matrix (DTM)
dtm <- DocumentTermMatrix(mycorpus)

# Check the DTM structure
inspect(dtm)

# Set number of topics for LDA
k <- 3

# Apply LDA topic modeling using the VEM (Variational EM) method
lda_output <- LDA(dtm, k, method = "VEM")

# Check the number of topics (k is already known, but just to confirm)
print(k)

# Get a summary of the LDA output
summary(lda_output)

# View the topics in the LDA model
topics(lda_output)

# View the top 10 terms for each topic
terms(lda_output, 10)

# Get the document-topic distribution (probabilities of each topic for each document)
posterior(lda_output)$topics

# View the topic-term matrix
topic_terms <- terms(lda_output, 10)
print(topic_terms)

